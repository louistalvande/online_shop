{
  "name": "e2e",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "test": "node --env-file=.env ./node_modules/.bin/playwright test",
    "test:admin": "node --env-file=.env ./node_modules/.bin/playwright test --project=admin-console",
    "test:buyer": "node --env-file=.env ./node_modules/.bin/playwright test --project=buyer-portal",
    "test:docker": "node --env-file=.env.docker ./node_modules/.bin/playwright test",
    "test:docker:admin": "node --env-file=.env.docker ./node_modules/.bin/playwright test --project=admin-console",
    "test:docker:vendor": "node --env-file=.env.docker ./node_modules/.bin/playwright test --project=vendor-portal",
    "test:docker:buyer": "node --env-file=.env.docker ./node_modules/.bin/playwright test --project=buyer-portal"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "pg": "^8.12.0"
  }
}
