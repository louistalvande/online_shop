@startuml oa-use-case-fr
skinparam actorStyle awesome
skinparam defaultFontSize 11
skinparam shadowing false
skinparam ArrowColor #2E75B6
skinparam actorBorderColor #2E75B6
skinparam usecaseBorderColor #2E75B6
skinparam usecaseBackgroundColor #E8F4FD
skinparam rectangleBorderColor #2E75B6

left to right direction

actor "Administrateur" as Admin
actor "Vendeur" as Vendor
actor "Acheteur" as Buyer

rectangle "Application e-commerce" {
  usecase "Gérer les comptes\nutilisateurs" as UC1
  usecase "Gérer le catalogue\nproduits" as UC2
  usecase "Passer une commande" as UC3
  usecase "Suivre les commandes" as UC4
  usecase "Parcourir le catalogue" as UC5
}

Admin --> UC1
Vendor --> UC2
Vendor --> UC4
Buyer --> UC3
Buyer --> UC5

@enduml
