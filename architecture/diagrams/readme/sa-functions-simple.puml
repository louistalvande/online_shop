@startuml sa-functions-simple
skinparam componentStyle rectangle
skinparam defaultFontSize 9
skinparam shadowing false
skinparam ArrowColor #444444
skinparam componentBackgroundColor #FEFEFE
skinparam componentBorderColor #2E75B6
skinparam packageBackgroundColor #EEF4FB
skinparam packageBorderColor #2E75B6

left to right direction

actor "Administrateur" as Admin
actor "Vendeur" as Vendor
actor "Acheteur" as Buyer
rectangle "Prestataire\nde paiement" as Pay
rectangle "Transporteur" as Carrier

rectangle "Système — Application e-commerce" {
  package "Comptes" {
    [FS-A01\nComptes & rôles] as A01
    [FS-A05\nMaintenance] as A05
  }
  package "Catalogue & stocks" {
    [FS-V02\nCatalogue CRUD] as V02
    [FS-V04\nCommandes] as V04
    [FS-V05\nExpédition] as V05
  }
  package "Expérience achat" {
    [FS-B01\nInscription] as B01
    [FS-B03\nCatalogue] as B03
    [FS-B06\nTunnel d'achat] as B06
    [FS-B07\nPaiement] as B07
    [FS-B09\nAnnulation] as B09
  }
  package "Interfaces externes" {
    [FS-P01\nAutorisation] as P01
    [FS-P03\nRemboursement] as P03
    [FS-C01\nSuivi colis] as C01
  }

  B03 --> V02
  B06 --> B07
  B07 --> P01
  B09 --> P03
  V05 --> C01
  A01 --> B01
}

Admin --> A01
Admin --> A05
Vendor --> V02
Vendor --> V04
Vendor --> V05
Buyer --> B01
Buyer --> B03
Buyer --> B06
Buyer --> B09
P01 --> Pay
P03 --> Pay
C01 --> Carrier

@enduml
