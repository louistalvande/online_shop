@startuml oa-use-case-en
skinparam actorStyle awesome
skinparam defaultFontSize 11
skinparam shadowing false
skinparam ArrowColor #2E75B6
skinparam actorBorderColor #2E75B6
skinparam usecaseBorderColor #2E75B6
skinparam usecaseBackgroundColor #E8F4FD
skinparam rectangleBorderColor #2E75B6

left to right direction

actor "Administrator" as Admin
actor "Seller" as Vendor
actor "Buyer" as Buyer

rectangle "E-commerce Application" {
  usecase "Manage user\naccounts" as UC1
  usecase "Manage product\ncatalogue" as UC2
  usecase "Place an order" as UC3
  usecase "Track orders" as UC4
  usecase "Browse catalogue" as UC5
}

Admin --> UC1
Vendor --> UC2
Vendor --> UC4
Buyer --> UC3
Buyer --> UC5

@enduml
