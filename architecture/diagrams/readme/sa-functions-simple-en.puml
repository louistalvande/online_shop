@startuml sa-functions-simple-en
skinparam componentStyle rectangle
skinparam defaultFontSize 9
skinparam shadowing false
skinparam ArrowColor #444444
skinparam componentBackgroundColor #FEFEFE
skinparam componentBorderColor #2E75B6
skinparam packageBackgroundColor #EEF4FB
skinparam packageBorderColor #2E75B6

left to right direction

actor "Administrator" as Admin
actor "Seller" as Vendor
actor "Buyer" as Buyer
rectangle "Payment\nProvider" as Pay
rectangle "Carrier" as Carrier

rectangle "System — E-commerce Application" {
  package "Accounts" {
    [FS-A01\nAccounts & roles] as A01
    [FS-A05\nMaintenance] as A05
  }
  package "Catalogue & stock" {
    [FS-V02\nCatalogue CRUD] as V02
    [FS-V04\nOrders] as V04
    [FS-V05\nShipping] as V05
  }
  package "Shopping experience" {
    [FS-B01\nRegistration] as B01
    [FS-B03\nCatalogue] as B03
    [FS-B06\nCheckout] as B06
    [FS-B07\nPayment] as B07
    [FS-B09\nCancellation] as B09
  }
  package "External interfaces" {
    [FS-P01\nAuthorisation] as P01
    [FS-P03\nRefund] as P03
    [FS-C01\nParcel tracking] as C01
  }

  B03 --> V02
  B06 --> B07
  B07 --> P01
  B09 --> P03
  V05 --> C01
  A01 --> B01
}

Admin --> A01
Admin --> A05
Vendor --> V02
Vendor --> V04
Vendor --> V05
Buyer --> B01
Buyer --> B03
Buyer --> B06
Buyer --> B09
P01 --> Pay
P03 --> Pay
C01 --> Carrier

@enduml
